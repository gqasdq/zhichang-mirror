# ====== LLM API Keys ======
# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 智谱GLM API
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# ====== 扣子Coze配置（MVP备用） ======
COZE_API_KEY=your_coze_api_key_here
COZE_BOT_ID_EMOTION=your_emotion_bot_id
COZE_BOT_ID_GOLD=your_gold_bot_id
COZE_BOT_ID_GENE=your_gene_bot_id

# ====== 应用配置 ======
APP_NAME=职场镜子
APP_VERSION=1.0.0
APP_ENV=development

# ====== 数据库配置 ======
DATABASE_PATH=./data/zhijing.db

# ====== FAISS / Embedding 配置 ======
# 无法访问 HuggingFace 时建议开启，检索将自动降级为关键词匹配
DISABLE_EMBEDDING=false
# HF_ENDPOINT=https://hf-mirror.com
# ALLOW_EMBEDDING_DOWNLOAD=true

FAISS_INDEX_PATH=./vectorstore
VECTOR_DIM=1024

# ====== 日志配置 ======
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ====== 缓存配置 ======
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# ====== 请求限流 ======
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEEPSEEK=60
RATE_LIMIT_ZHIPU=120
